# 全局API速率限制开关
GLOBAL_API_RATE_LIMIT_ENABLE=true
# 全局API速率限制(单IP)
GLOBAL_API_RATE_LIMIT=500
# 全局API速率限制窗口(秒)
GLOBAL_WEB_RATE_LIMIT_DURATION=500
# 全局Web速率限制开关
GLOBAL_WEB_RATE_LIMIT_ENABLE=true
# 全局Web速率限制(单IP)
GLOBAL_WEB_RATE_LIMIT=200
# 关键操作速率限制开关
GLOBAL_WEB_RATE_LIMIT_ENABLE=true
# 关键操作速率限制次数
CRITICAL_RATE_LIMIT=100
